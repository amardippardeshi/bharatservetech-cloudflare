# Text files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.ps1  text eol=lf

# Force UTF-8 normalization (safe modern Git standard)
* text=auto

# Prevent binary corruption
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary